PORT=3001
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/coorg-spices?retryWrites=true&w=majority
JWT_SECRET=your_secure_jwt_secret_key_change_this_in_production

# Payment Gateway Credentials
# Get these from your payment gateway dashboards

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Bank Account Details (for receiving payments)
BANK_ACCOUNT_NUMBER=your_bank_account_number
BANK_IFSC_CODE=your_bank_ifsc_code
BANK_NAME=your_bank_name
